<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Blog</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <h1>Welcome to My Blog Website</h1>
    <p>This is my first Express + Ejs project.</p>
    <a href="/create">
      <button>Create New Blog</button>
    </a>
    <hr>
    <h2>All Blogs</h2>
    <% blogs.forEach((blog, index) =>{ %>
       <div class="blog-card">
        <a href="/blog/<%= index  %>">Read More</a>
        <h3><%= blog.title %></h3>
        <p><strong>Author:</strong><%= blog.author %></p>
        <p><%= blog.content %></p>
        </div>
        <hr>
    <% }) %>
  </body>
</html>
